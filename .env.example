# Configuracao do Banco de Dados PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=capital_db
DB_USERNAME=capital_user
DB_PASSWORD=capital_secret

# Configuracao do Backend Laravel
APP_NAME="Sistema Capital"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Configuracao do Frontend React
VITE_API_URL=http://localhost:8000
